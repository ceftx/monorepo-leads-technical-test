{
    "name": "leads-monorepo",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "start": "npm run build:backend && npm run start:backend",
        "start:backend": "npm run start --workspace=@leads/backend",
        "dev:backend": "npm run dev --workspace=@leads/backend",
        "dev:frontend": "npm run dev --workspace=@leads/frontend",
        "dev": "npm run dev:backend & npm run dev:frontend",
        "build": "npm run build --workspaces",
        "build:backend": "npm run build --workspace=@leads/backend",
        "build:frontend": "npm run build --workspace=@leads/frontend",
        "format": "prettier --write \"**/*.{js,ts,json,md,tsx,jsx}\""
    },
    "devDependencies": {
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    }
}
