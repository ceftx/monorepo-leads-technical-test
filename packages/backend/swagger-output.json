{
  "openapi": "3.0.0",
  "info": {
    "title": "Leads Management API",
    "description": "API para gestión de leads con autenticación JWT y roles (ADMIN/VENDEDOR)",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://monorepo-leads-technical-back-production.up.railway.app/api"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Endpoints de autenticación"
    },
    {
      "name": "Leads",
      "description": "Gestión de leads"
    },
    {
      "name": "Users",
      "description": "Gestión de usuarios (solo ADMIN)"
    },
    {
      "name": "Dashboard",
      "description": "Métricas y estadísticas"
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "description": "Crea un nuevo usuario en el sistema",
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "example": "any"
                  },
                  "password": {
                    "example": "any"
                  },
                  "nombre": {
                    "example": "any"
                  },
                  "rol": {
                    "example": "any"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Auth"
        ],
        "summary": "Registrar nuevo usuario"
      }
    },
    "/api/auth/login": {
      "post": {
        "description": "Autentica un usuario y devuelve un token JWT",
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "example": "any"
                  },
                  "password": {
                    "example": "any"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Auth"
        ],
        "summary": "Iniciar sesión"
      }
    },
    "/api/auth/refresh": {
      "post": {
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "example": "any"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/leads/{id}": {
      "get": {
        "description": "Vendedor: solo sus leads. Admin: cualquier lead",
