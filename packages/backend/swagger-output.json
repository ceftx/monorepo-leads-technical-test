              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "tags": [
          "Leads"
        ],
        "summary": "Obtener un lead por ID"
      },
      "put": {
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": {
                    "example": "any"
                  },
                  "email": {
                    "example": "any"
                  },
                  "empresa": {
                    "example": "any"
                  },
                  "montoEstimado": {
                    "example": "any"
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "description": "Vendedor: solo sus leads. Admin: cualquier lead",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "tags": [
          "Leads"
        ],
        "summary": "Eliminar un lead"
      }
    },
    "/api/leads/{id}/status": {
      "patch": {
        "description": "Vendedor: solo sus leads. Admin: cualquier lead",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": {
                    "example": "any"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Leads"
        ],
        "summary": "Actualizar estado de un lead"
      }
    },
    "/api/users/{id}": {
      "delete": {
        "description": "Elimina un usuario del sistema",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "tags": [
          "Users"
        ],
        "summary": "Eliminar un usuario (solo ADMIN)"
      }
    },
    "/api/dashboard/user": {
      "get": {
        "description": "Devuelve estadísticas y métricas del usuario actual",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "tags": [
          "Dashboard"
        ],
        "summary": "Obtener métricas del usuario autenticado"
      }
    },
    "/api/dashboard/user/{id}": {
      "get": {
        "description": "Devuelve estadísticas de un usuario específico",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "tags": [
          "Dashboard"
        ],
        "summary": "Obtener métricas de un usuario específico (solo ADMIN)"
      }
    },
    "/api/dashboard/global": {
      "get": {
        "description": "Devuelve estadísticas globales y ranking de vendedores",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "tags": [
          "Dashboard"
        ],
        "summary": "Obtener métricas globales del sistema (solo ADMIN)"
      }
    },
    "/api/leads": {
      "post": {
        "description": "Crea un lead. Vendedor: asignado a sí mismo. Admin: puede especificar userId",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": {
                    "example": "any"
                  },
                  "email": {
                    "example": "any"
                  },
                  "empresa": {
                    "example": "any"
                  },
                  "montoEstimado": {
                    "example": "any"
                  },
                  "userId": {
                    "example": "any"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Leads"
        ],
        "summary": "Crear nuevo lead"
      },
      "get": {
        "description": "Vendedor: solo ve sus leads. Admin: ve todos (o filtra por userId)",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "userId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "tags": [
          "Leads"
        ],
        "summary": "Obtener todos los leads del usuario"
      }
    },
    "/api/users": {
      "get": {
        "description": "Lista todos los usuarios del sistema",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "tags": [
          "Users"
        ],
        "summary": "Obtener todos los usuarios (solo ADMIN)"
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "nombre": {
            "type": "string",
            "example": "John Doe"
          },
          "rol": {
            "type": "string",
            "example": "VENDEDOR"
          },
          "createdAt": {
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          }
        }
      },
      "Lead": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "nombre": {
            "type": "string",
            "example": "Jane Smith"
          },
          "email": {
            "type": "string",
            "example": "jane@company.com"
          },
          "empresa": {
            "type": "string",
            "example": "Tech Corp"
          },
          "montoEstimado": {
            "type": "number",
            "example": 50000
          },
          "estado": {
            "type": "string",
            "example": "NUEVO"
          },
          "userId": {
            "type": "number",
            "example": 1
          },
          "createdAt": {
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          },
          "nombre": {
            "type": "string",
            "example": "John Doe"
          },
          "rol": {
            "type": "string",
            "example": "VENDEDOR"
          }
        },
        "required": [
          "email",
          "password",
          "nombre"
        ]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshTokenRequest": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": [
          "token"
        ]
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "CreateLeadRequest": {
        "type": "object",
        "properties": {
          "nombre": {
            "type": "string",
            "example": "Jane Smith"
          },
          "email": {
            "type": "string",
            "example": "jane@company.com"
          },
          "empresa": {
            "type": "string",
            "example": "Tech Corp"
          },
          "montoEstimado": {
            "type": "number",
            "example": 50000
          }
        },
        "required": [
          "nombre",
          "email",
          "empresa",
          "montoEstimado"
        ]
      },
      "UpdateLeadStatusRequest": {
        "type": "object",
        "properties": {
          "estado": {
            "type": "string",
            "example": "CONTACTADO"
          }
        },
        "required": [
          "estado"
        ]
      },
      "UserMetrics": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "number",
            "example": 1
          },
          "nombreUsuario": {
            "type": "string",
            "example": "John Doe"
          },
          "totalLeads": {
            "type": "number",
            "example": 10
          },
          "distribucionPorEstado": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "estado": {
                  "type": "string",
                  "example": "NUEVO"
                },
                "cantidad": {
                  "type": "number",
                  "example": 5
                }
              }
            }
          },
          "montoEstimadoTotal": {
            "type": "number",
            "example": 500000
          },
          "leadsUltimos7Dias": {
            "type": "number",
            "example": 5
          },
          "leadsRecientes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Lead"
            }
          }
        }
      },
      "GlobalMetrics": {
        "type": "object",
        "properties": {
          "totalLeads": {
            "type": "number",
            "example": 50
          },
          "distribucionPorEstado": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "estado": {
                  "type": "string",
                  "example": "NUEVO"
                },
                "cantidad": {
                  "type": "number",
                  "example": 20
                }
              }
            }
          },
          "montoEstimadoTotal": {
            "type": "number",
            "example": 2500000
          },
          "leadsUltimos7Dias": {
            "type": "number",
            "example": 15
          },
          "leadsRecientes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Lead"
            }
          },
          "totalUsuarios": {
            "type": "number",
            "example": 10
          },
          "rankingVendedores": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "userId": {
                  "type": "number",
                  "example": 2
                },
                "nombreVendedor": {
                  "type": "string",
                  "example": "John Doe"
                },
                "montoGanado": {
                  "type": "number",
                  "example": 150000
                },
                "leadsGanados": {
                  "type": "number",
                  "example": 5
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "ERROR_CODE"
              },
              "message": {
                "type": "string",
                "example": "Error message"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "in": "header",
        "description": "JWT token. Formato: Bearer {token}"
      }
    }
  }
}