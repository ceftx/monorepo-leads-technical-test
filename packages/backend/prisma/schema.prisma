// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  VENDEDOR
}

enum LeadStatus {
  NUEVO
  CONTACTADO
  GANADO
  PERDIDO
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique @db.VarChar(255)
  password      String         @db.VarChar(255) // Hash de bcrypt
  nombre        String         @db.VarChar(100)
  rol           UserRole       @default(VENDEDOR)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  leads         Lead[] // Relación 1:N
  notifications Notification[] // Relación 1:N
}

model Lead {
  id            Int        @id @default(autoincrement())
  nombre        String     @db.VarChar(100)
  email         String     @db.VarChar(255) // NO unique
  empresa       String     @db.VarChar(200)
  montoEstimado Decimal    @db.Decimal(12, 2) // Hasta 9,999,999,999.99
  estado        LeadStatus @default(NUEVO)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  userId        Int
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId]) // Filtrar por usuario
  @@index([estado]) // Métricas por estado
  @@index([createdAt]) // Ordenar por fecha
}

enum NotificationType {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  LEAD_DELETED
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  message   String           @db.VarChar(500)
  data      Json? // Metadata adicional (leadId, oldStatus, newStatus, etc)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read]) // Consultas por usuario no leídas
  @@index([createdAt]) // Ordenar por fecha
}
